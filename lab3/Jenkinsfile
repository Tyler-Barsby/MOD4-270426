pipeline {
    agent any

    parameters {
        base64File(name: 'UPLOAD', description: 'Upload a file to process')
    }

    stages {
        stage('Receive File') {
            steps {
                withFileParameter('UPLOAD') {
                    sh 'cp $UPLOAD received_file'
                }
            }
        }

        stage('Detect & Process') {
            steps {
                sh 'python3 lab3/router.py received_file'
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'processed_file.*', allowEmptyArchive: true
            }
        }
    }
}