pipeline {
    agent any

    parameters {
        base64File(name: 'UPLOAD', description: 'Upload a file to process')
    }

    stages {
        stage('Receive File') {
            steps {
                withFileParameter('UPLOAD') {
                    sh 'cp $UPLOAD received_file.txt'
                }
            }
        }

        stage('Process File') {
            steps {
                sh 'python3 script.py received_file.txt processed_file.txt'
            }
        }
        stage('Debug') {
            steps {
                sh 'pwd'
                sh 'ls -la'
                sh 'find . -name "script.py"'
            }
        } 

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: 'processed_file.txt'
            }
        }
    }
}